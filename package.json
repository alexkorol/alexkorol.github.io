{
  "name": "alexkorol-ai-engineering-portfolio",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "homepage": "https://alexkorol.github.io",
  "scripts": {
    "content": "tsx scripts/generate-content.ts",
    "dev": "npm run content && vite",
    "build:client": "vite build",
    "prerender": "tsx scripts/prerender.tsx",
    "build": "npm run content && npm run build:client && npm run prerender",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "npm run content && tsc --noEmit && tsc -p worker/tsconfig.json --noEmit",
    "test": "npm run content && vitest run",
    "test:watch": "vitest",
    "eval": "npm run content && tsx evals/run.ts",
    "eval:live": "npm run content && tsx evals/run.ts --live",
    "worker:dev": "npm run content && wrangler dev --config worker/wrangler.toml",
    "worker:deploy": "npm run content && wrangler deploy --config worker/wrangler.toml"
  },
  "dependencies": {
    "marked": "^15.0.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@eslint/js": "^9.30.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.34",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "gray-matter": "^4.0.3",
    "jsdom": "^26.1.0",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.34.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "6.3.5",
    "vitest": "^3.2.4",
    "wrangler": "^4.23.0"
  }
}
